#!/usr/bin/env bash

BIN0=$(readlink -f $0)
DIR0=$(dirname $BIN0)
ROOT_DIR="$(dirname $DIR0)/src"

cd $ROOT_DIR

list_files() {
  fd --no-ignore -e html -e css -e js . | grep -v templates
}

for FILE in $(list_files); do
  BASE=$(dirname $FILE)
  ssh jino "mkdir -p ~/hosts/html/$BASE"
  scp "$FILE" "jino:~/hosts/html/$FILE"
done

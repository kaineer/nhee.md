#!/usr/bin/env bash

BIN0=$(readlink -f $0)
DIR0=$(dirname $BIN0)
ROOT_DIR="$(dirname $DIR0)/src"

cd $ROOT_DIR

echo -n " $(ansi white bold)»$(ansi reset) Deploy html, css, js and ttf files to nhee.ru.."

rsync -a \
  --exclude='templates' \
  --include='*/' \
  --include='*.html' \
  --include='*.css' \
  --include='*.js' \
  --include='*.ttf' \
  --exclude='*' \
  . jino:/home/kaineer/hosts/html

echo "done"
